{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.electron.tsbuildinfo",
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "skipLibCheck": true,

    "moduleResolution": "nodenext",
    "moduleDetection": "force",
    "outDir": "dist-tsc",
    "strict": true
  },
  "include": ["src/main", "src/preload", "types"]
}
